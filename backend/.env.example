# Copy this file to .env and adjust values for your environment.
# All variables are optional — sensible defaults are baked into src/config/index.js.

# vLLM OpenAI-compatible server
VLLM_URL=http://127.0.0.1:8001

# Model name sent in chat payloads
MODEL=nvidia/Cosmos3-Nano

# Express port
PORT=7086

# External allocation/thermal data backend (OASIS), proxied under /api/oasis/*
OASIS_API=http://103.204.95.220:7040

ALLOC_BASE=

# Minutes of inactivity before the vLLM subprocess is auto-killed
IDLE_TIMEOUT_MIN=10

# Tensor-parallel GPU count for the vLLM subprocess (1 = single-GPU mode)
COSMOS_TP=2
